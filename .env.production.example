# ══════════════════════════════════════════════════════
# ReelsMaker — Production Environment Variables
# 클라우드 배포용 (Railway + Neon + R2 + Clerk)
# ══════════════════════════════════════════════════════

# ── Database (Neon) ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/reelsmaker?sslmode=require

# ── Redis (Railway / Upstash) ─────────────────────────
REDIS_URL=redis://default:password@host:port

# ── Object Storage (Cloudflare R2) ────────────────────
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_PUBLIC_ENDPOINT=https://pub-xxx.r2.dev
S3_ACCESS_KEY=R2_ACCESS_KEY_ID
S3_SECRET_KEY=R2_SECRET_ACCESS_KEY
S3_BUCKET=reelsmaker
S3_REGION=auto

# ── Auth (Clerk) ──────────────────────────────────────
AUTH_ENABLED=true
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev

# ── AI Provider Keys ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
GOOGLE_API_KEY=AIza...
HIGGSFIELD_API_KEY_ID=
HIGGSFIELD_API_KEY_SECRET=
ELEVENLABS_API_KEY=

# ── Provider Selection ────────────────────────────────
IMAGE_PROVIDER=gemini
VIDEO_PROVIDER=higgsfield
TTS_PROVIDER=elevenlabs

# ── Provider Models ───────────────────────────────────
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
HIGGSFIELD_MODEL=kling-video/v2.1/pro/image-to-video

# ── App Behavior ──────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["https://your-app.vercel.app"]
PROVIDER_TIMEOUT_SEC=180
