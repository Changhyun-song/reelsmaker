# ══════════════════════════════════════════════════════
# ReelsMaker — Environment Variables
# cp .env.example .env  후 값을 수정하세요.
# ══════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────
POSTGRES_USER=reelsmaker
POSTGRES_PASSWORD=reelsmaker
POSTGRES_DB=reelsmaker
POSTGRES_PORT=5432
# Docker 내부에서는 docker-compose가 DATABASE_URL을 자동 구성합니다.
# 로컬 개발 시만 설정:
# DATABASE_URL=postgresql+asyncpg://reelsmaker:reelsmaker@localhost:5432/reelsmaker

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ── Object Storage (S3 / R2 / MinIO) ─────────────────
# 로컬: MinIO (http://localhost:9000)
# 프로덕션: Cloudflare R2 (https://<account>.r2.cloudflarestorage.com)
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=reelsmaker
S3_REGION=auto
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Service Ports ─────────────────────────────────────
API_PORT=8000
WEB_PORT=3000

# ── AI Provider Keys ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=                    # OpenAI 이미지 생성용
GOOGLE_API_KEY=                    # Google Gemini 이미지 생성용
FAL_KEY=                           # fal.ai (FLUX 이미지 + Kling 비디오)
RUNWAY_API_KEY=                    # Runway 비디오 생성용
LUMA_API_KEY=                      # Luma Dream Machine 비디오 생성용
HIGGSFIELD_API_KEY_ID=             # Higgsfield 이미지/비디오 생성용 (Key ID)
HIGGSFIELD_API_KEY_SECRET=         # Higgsfield 이미지/비디오 생성용 (Key Secret)
ELEVENLABS_API_KEY=                # ElevenLabs TTS용

# ── Provider Selection ────────────────────────────────
# "mock" = 로컬 placeholder (API 호출 없음, 무료)
# 실제 provider 이름 = API 키가 있으면 해당 서비스 호출

IMAGE_PROVIDER=mock          # "mock" | "fal" | "openai" | "gemini" | "higgsfield"
VIDEO_PROVIDER=mock          # "mock" | "runway" | "kling" | "luma" | "higgsfield"
TTS_PROVIDER=mock            # "mock" | "elevenlabs"

# ── Provider Model Selection ─────────────────────────
# Image models
FAL_IMAGE_MODEL=fal-ai/flux/schnell
OPENAI_IMAGE_MODEL=gpt-image-1
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
HIGGSFIELD_IMAGE_MODEL=google/nano-banana-2

# Video models
RUNWAY_MODEL=gen4_turbo
KLING_MODEL=fal-ai/kling-video/v2/master/image-to-video
LUMA_MODEL=ray-2
HIGGSFIELD_MODEL=kling-video/v2.1/pro/image-to-video

# TTS models
ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_DEFAULT_VOICE=       # ElevenLabs voice_id

# ── Provider Behavior ─────────────────────────────────
PROVIDER_TIMEOUT_SEC=120

# ── Auth (Clerk) ──────────────────────────────────────
# AUTH_ENABLED=false -> 로컬 개발 (인증 없이 local_dev_user로 동작)
# AUTH_ENABLED=true  -> 프로덕션 (Clerk JWT 필수)
AUTH_ENABLED=false
CLERK_SECRET_KEY=              # sk_test_... (Clerk dashboard)
CLERK_PUBLISHABLE_KEY=         # pk_test_... (Clerk dashboard)
CLERK_JWT_ISSUER=              # https://your-app.clerk.accounts.dev

# ── App Behavior ──────────────────────────────────────
DEBUG=true
LOG_LEVEL=INFO
# SQL_ECHO=false
